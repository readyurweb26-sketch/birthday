<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
    <title>✨ 2025 – Welcome ✨</title>
    <link rel="icon" type="image/jpeg" href="images/logo.jpeg">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            min-height: 100dvh;
            overflow: hidden;
            font-family: 'Segoe UI', 'Poppins', system-ui, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #0a0a0a;
            position: relative;
        }

        /* ===== RESPONSIVE BACKGROUND VIDEO ===== */
        #bgVideo {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            object-fit: cover;
            z-index: 0;
            opacity: 0;
            transition: opacity 0.8s ease;
            background: #000;
            /* Mobile hardware acceleration */
            -webkit-transform: translateZ(0);
            transform: translateZ(0);
        }

        #bgVideo.visible {
            opacity: 1;
        }

        /* ===== ENTRY OVERLAY ===== */
        #entryOverlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 100;
            background: rgba(0, 0, 0, 0.75);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.8s ease;
            pointer-events: none;
        }

        #entryOverlay.hidden {
            opacity: 0;
            pointer-events: none;
        }

        .welcome-text {
            font-size: clamp(2.5rem, 12vw, 6rem);
            font-weight: 900;
            color: #ffd700;
            text-shadow: 0 0 20px #ffd700, 0 0 40px #ff8c00, 0 0 80px #ff4500;
            animation: welcomePop 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            opacity: 0;
            transform: scale(0.5);
            text-align: center;
            padding: 0 1rem;
            letter-spacing: 2px;
        }

        @keyframes welcomePop {
            0% { opacity: 0; transform: scale(0.5) rotate(-5deg); }
            100% { opacity: 1; transform: scale(1) rotate(0deg); }
        }

        .welcome-sub {
            font-size: clamp(0.9rem, 3vw, 1.5rem);
            color: #ffefcf;
            margin-top: 1rem;
            opacity: 0.8;
            animation: fadeInUp 1s ease 0.5s forwards;
            opacity: 0;
            transform: translateY(20px);
        }

        @keyframes fadeInUp {
            to { opacity: 1; transform: translateY(0); }
        }

        /* ===== CONFETTI CANVAS ===== */
        #confettiCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 101;
        }

        /* ===== MUSIC BUTTON (top-right) ===== */
        .music-btn {
            position: fixed;
            top: 15px;
            right: 15px;
            z-index: 50;
            background: rgba(255, 200, 210, 0.9);
            backdrop-filter: blur(8px);
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 600;
            color: #5e2a2f;
            cursor: pointer;
            font-family: 'Segoe UI', sans-serif;
            opacity: 0;
            transform: translateY(-20px);
            transition: all 0.4s ease;
        }

        .music-btn.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .music-btn:hover {
            background: #ff99ae;
            transform: scale(1.02);
            color: white;
        }

        /* ===== BACK TO MAIN MENU (bottom-right) ===== */
        .menu-btn {
            position: fixed;
            bottom: 15px;
            right: 15px;
            z-index: 50;
            background: rgba(255, 200, 210, 0.9);
            backdrop-filter: blur(8px);
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 600;
            color: #5e2a2f;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            font-family: 'Segoe UI', sans-serif;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.4s ease;
        }

        .menu-btn.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .menu-btn:hover {
            background: #ff99ae;
            transform: scale(1.02);
            color: white;
        }

        /* ===== MAIN CONTENT ===== */
        .main-content {
            position: relative;
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100dvh;
            padding: 2rem;
            width: 100%;
            max-width: 900px;
            opacity: 0;
            transition: opacity 0.8s ease;
            pointer-events: none;
        }

        .main-content.visible {
            opacity: 1;
            pointer-events: auto;
        }

        /* Typewriter text */
        .typewriter-area {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .typewriter-text {
            font-size: clamp(1.5rem, 5vw, 3rem);
            font-weight: 700;
            color: #fff5e0;
            text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.8);
            font-family: 'Courier New', monospace;
            min-height: 80px;
            letter-spacing: 1px;
        }

        .typewriter-text .cursor {
            display: inline-block;
            width: 3px;
            height: 1em;
            background: #ffd700;
            margin-left: 4px;
            animation: blink 0.7s infinite;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        /* ===== CAROUSEL (single item visible) ===== */
        .carousel-container {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(12px);
            padding: 0.8rem 1.2rem;
            border-radius: 60px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
            min-width: 280px;
            justify-content: center;
        }

        .carousel-arrow {
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.5);
            font-size: 2rem;
            font-weight: 300;
            cursor: pointer;
            padding: 0.2rem 0.6rem;
            transition: all 0.25s ease;
            font-family: monospace;
            line-height: 1;
            user-select: none;
        }

        .carousel-arrow:hover {
            color: #ffd700;
            transform: scale(1.15);
            text-shadow: 0 0 15px rgba(255, 215, 0, 0.4);
        }

        .carousel-arrow:active {
            transform: scale(0.9);
        }

        .carousel-slide {
            min-width: 140px;
            text-align: center;
            overflow: hidden;
            position: relative;
        }

        .carousel-item {
            display: none;
            padding: 0.4rem 1.2rem;
            border-radius: 40px;
            font-size: 1.1rem;
            font-weight: 500;
            color: rgba(255, 255, 255, 0.7);
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            font-family: 'Segoe UI', sans-serif;
            letter-spacing: 0.5px;
            white-space: nowrap;
            border: 1px solid transparent;
            background: transparent;
        }

        .carousel-item.active {
            display: inline-block;
            animation: fadeSlide 0.3s ease forwards;
        }

        @keyframes fadeSlide {
            0% { opacity: 0; transform: translateY(8px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        .carousel-item:hover {
            background: rgba(255, 215, 0, 0.15);
            color: #ffd700;
            border-color: rgba(255, 215, 0, 0.3);
            transform: scale(1.05);
            box-shadow: 0 0 25px rgba(255, 215, 0, 0.1);
        }

        .carousel-item.active-item {
            background: rgba(255, 215, 0, 0.2);
            color: #ffd700;
            border-color: rgba(255, 215, 0, 0.4);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 600px) {
            .carousel-container {
                padding: 0.5rem 0.8rem;
                gap: 0.4rem;
                min-width: auto;
                width: 90%;
                max-width: 380px;
            }
            .carousel-slide {
                min-width: 100px;
            }
            .carousel-item {
                padding: 0.3rem 0.8rem;
                font-size: 0.9rem;
            }
            .carousel-arrow {
                font-size: 1.6rem;
                padding: 0 0.3rem;
            }
            .typewriter-text {
                font-size: clamp(1.2rem, 4vw, 1.8rem);
                min-height: 60px;
            }
            .music-btn, .menu-btn {
                padding: 0.3rem 0.7rem;
                font-size: 0.65rem;
            }
        }

        @media (max-width: 400px) {
            .carousel-slide {
                min-width: 80px;
            }
            .carousel-item {
                font-size: 0.8rem;
                padding: 0.2rem 0.6rem;
            }
            .carousel-arrow {
                font-size: 1.3rem;
            }
        }

        /* ===== RESPONSIVE VIDEO FIX: Landscape phones ===== */
        @media (orientation: landscape) and (max-height: 500px) {
            .main-content {
                padding: 1rem;
            }
            .typewriter-text {
                font-size: clamp(1rem, 3vw, 1.5rem);
                min-height: 40px;
            }
            .typewriter-area {
                margin-bottom: 1rem;
            }
            .carousel-container {
                padding: 0.4rem 0.8rem;
            }
        }
    </style>
</head>
<body>

    <!-- ===== RESPONSIVE BACKGROUND VIDEO ===== -->
    <video id="bgVideo" autoplay loop muted playsinline preload="auto">
        <!-- 👇 CHANGE THIS VIDEO URL -->
        <source src="Videos/Chitta.mp4" type="video/mp4">
        <!-- Fallback: if video fails, show black background -->
    </video>

    <!-- ===== ENTRY OVERLAY ===== -->
    <div id="entryOverlay">
        <div class="welcome-text">✨ Welcome Birthday Girl ✨</div>
        <div class="welcome-sub">🎉 Let the celebration begin 🎉</div>
    </div>

    <!-- ===== CONFETTI CANVAS ===== -->
    <canvas id="confettiCanvas"></canvas>

    <!-- ===== MUSIC BUTTON ===== -->
    <button id="musicToggleBtn" class="music-btn">🔇 Music Off</button>

    <!-- ===== BACK TO MAIN MENU ===== -->
    <a href="index.html" class="menu-btn" id="menuBtn">🏠 Main Menu</a>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="main-content" id="mainContent">
        <div class="typewriter-area">
            <div class="typewriter-text" id="typewriterText"></div>
        </div>

        <div class="carousel-container">
            <button class="carousel-arrow" id="prevBtn" aria-label="Previous">‹</button>
            <div class="carousel-slide" id="carouselSlide">
                <a href="image.html" class="carousel-item" data-option="image">🖼️ image</a>
                <a href="video.html" class="carousel-item" data-option="video">📹 video</a>
                <a href="tatti.html" class="carousel-item" data-option="tatti">💩 tatti</a>
            </div>
            <button class="carousel-arrow" id="nextBtn" aria-label="Next">›</button>
        </div>
    </div>

    <script>
        // ═══ DISABLE RIGHT-CLICK & DEVTOOLS KEYS ═══
document.addEventListener('contextmenu', e => e.preventDefault());
document.onkeydown = function(e) {
    if (e.keyCode == 123 || (e.ctrlKey && e.shiftKey && e.keyCode == 73)) {
        return false;
    }
};
        // ================================================================
        // 1. CONFETTI / CRACKER ANIMATION
        // ================================================================
        const canvas = document.getElementById('confettiCanvas');
        const ctx = canvas.getContext('2d');
        let W, H;

        function resizeCanvas() {
            W = window.innerWidth;
            H = window.innerHeight;
            canvas.width = W;
            canvas.height = H;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        let particles = [];

        function createParticles(count = 120) {
            const colors = ['#ff0', '#f0f', '#0ff', '#f44', '#4f4', '#44f', '#ff8800', '#ff44aa', '#aaff44', '#ffaa00'];
            for (let i = 0; i < count; i++) {
                const angle = Math.random() * Math.PI * 2;
                const speed = 4 + Math.random() * 12;
                particles.push({
                    x: W / 2 + (Math.random() - 0.5) * 100,
                    y: H / 2 + (Math.random() - 0.5) * 80,
                    vx: Math.cos(angle) * speed * (0.6 + Math.random() * 0.6),
                    vy: Math.sin(angle) * speed * (0.6 + Math.random() * 0.6) - 2,
                    size: 4 + Math.random() * 10,
                    color: colors[Math.floor(Math.random() * colors.length)],
                    life: 1,
                    decay: 0.005 + Math.random() * 0.015,
                    rotation: Math.random() * 360,
                    rotSpeed: (Math.random() - 0.5) * 0.2,
                    shape: Math.random() > 0.5 ? 'rect' : 'circle'
                });
            }
        }

        function createSideBurst() {
            const colors = ['#ff0', '#f44', '#4f4', '#44f', '#ff8800', '#ff44aa', '#aaff44'];
            for (let i = 0; i < 40; i++) {
                const side = Math.floor(Math.random() * 4);
                let x, y;
                if (side === 0) { x = Math.random() * W; y = -20; }
                else if (side === 1) { x = Math.random() * W; y = H + 20; }
                else if (side === 2) { x = -20; y = Math.random() * H; }
                else { x = W + 20; y = Math.random() * H; }
                const angle = Math.random() * Math.PI * 2;
                const speed = 3 + Math.random() * 8;
                particles.push({
                    x, y,
                    vx: Math.cos(angle) * speed,
                    vy: Math.sin(angle) * speed - 1,
                    size: 3 + Math.random() * 8,
                    color: colors[Math.floor(Math.random() * colors.length)],
                    life: 1,
                    decay: 0.008 + Math.random() * 0.015,
                    rotation: Math.random() * 360,
                    rotSpeed: (Math.random() - 0.5) * 0.15,
                    shape: 'rect'
                });
            }
        }

        function animateConfetti() {
            ctx.clearRect(0, 0, W, H);
            for (let i = particles.length - 1; i >= 0; i--) {
                const p = particles[i];
                p.x += p.vx;
                p.y += p.vy;
                p.vy += 0.08;
                p.vx *= 0.99;
                p.vy *= 0.99;
                p.life -= p.decay;
                p.rotation += p.rotSpeed;
                if (p.life <= 0 || p.y > H + 50 || p.x < -50 || p.x > W + 50) {
                    particles.splice(i, 1);
                    continue;
                }
                ctx.save();
                ctx.translate(p.x, p.y);
                ctx.rotate(p.rotation * Math.PI / 180);
                ctx.globalAlpha = p.life;
                ctx.fillStyle = p.color;
                if (p.shape === 'rect') {
                    ctx.fillRect(-p.size / 2, -p.size / 3, p.size, p.size * 0.6);
                } else {
                    ctx.beginPath();
                    ctx.arc(0, 0, p.size / 2, 0, Math.PI * 2);
                    ctx.fill();
                }
                ctx.restore();
            }
            requestAnimationFrame(animateConfetti);
        }

        createParticles(150);
        setTimeout(() => createSideBurst(), 300);
        setTimeout(() => createSideBurst(), 700);
        setTimeout(() => createParticles(80), 1200);
        setTimeout(() => createSideBurst(), 1800);
        animateConfetti();

        // ================================================================
        // 2. ENTRY OVERLAY + SHOW CONTENT (pageshow fix for back/forward)
        // ================================================================
        const entryOverlay = document.getElementById('entryOverlay');
        const mainContent = document.getElementById('mainContent');
        const bgVideo = document.getElementById('bgVideo');
        const musicBtn = document.getElementById('musicToggleBtn');
        const menuBtn = document.getElementById('menuBtn');
        const typewriterEl = document.getElementById('typewriterText');

        function showContent() {
            entryOverlay.classList.add('hidden');
            bgVideo.classList.add('visible');
            mainContent.classList.add('visible');
            musicBtn.classList.add('visible');
            menuBtn.classList.add('visible');
            bgVideo.play().catch(e => console.log('Video autoplay blocked:', e));
        }

        function startTypewriterNow() {
            if (window.typewriterStarted) return;
            window.typewriterStarted = true;
            typewriterEl.innerHTML = '';
            const msg = "what you wanna see first";
            let idx = 0;
            const interval = setInterval(() => {
                if (idx < msg.length) {
                    typewriterEl.innerHTML += msg.charAt(idx);
                    idx++;
                } else {
                    clearInterval(interval);
                    const cursor = document.createElement('span');
                    cursor.className = 'cursor';
                    typewriterEl.appendChild(cursor);
                }
            }, 70);
        }

        // pageshow event handles both fresh load and back/forward (bfcache)
        window.addEventListener('pageshow', function(event) {
            const referrer = document.referrer;
            const cameFromInternal = 
                referrer.includes('image.html') ||
                referrer.includes('video.html') ||
                referrer.includes('tatti.html') ||
                referrer.includes('year2021.html') ||
                referrer.includes('year2022.html') ||
                referrer.includes('year2023.html') ||
                referrer.includes('year2024.html') ||
                referrer.includes('year2025.html') ||
                referrer.includes('year2026.html') ||
                referrer.includes('year2027.html') ||
                referrer.includes('guide.html');

            if (event.persisted || cameFromInternal) {
                showContent();
                startTypewriterNow();
            } else {
                setTimeout(() => {
                    showContent();
                }, 1500);
                setTimeout(() => {
                    startTypewriterNow();
                }, 1800);
            }
        });

        // ================================================================
        // 3. CAROUSEL LOGIC
        // ================================================================
        const items = document.querySelectorAll('.carousel-item');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        let currentIndex = 0;
        const totalItems = items.length;

        function showItem(index) {
            items.forEach((item, i) => {
                item.classList.remove('active', 'active-item');
                if (i === index) {
                    item.classList.add('active', 'active-item');
                }
            });
        }

        function goToItem(index) {
            if (index < 0) index = totalItems - 1;
            if (index >= totalItems) index = 0;
            currentIndex = index;
            showItem(currentIndex);
        }

        prevBtn.addEventListener('click', () => { goToItem(currentIndex - 1); });
        nextBtn.addEventListener('click', () => { goToItem(currentIndex + 1); });

        items.forEach((item) => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                const option = item.dataset.option;
                window.location.href = `${option}.html`;
            });
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowLeft') prevBtn.click();
            else if (e.key === 'ArrowRight') nextBtn.click();
            else if (e.key === 'Enter') {
                const active = document.querySelector('.carousel-item.active');
                if (active) active.click();
            }
        });

        showItem(0);

        // ================================================================
        // 4. MUSIC BUTTON (controls video audio)
        // ================================================================
        let isMusicPlaying = false;
        bgVideo.muted = true;

        musicBtn.addEventListener('click', () => {
            if (isMusicPlaying) {
                bgVideo.muted = true;
                musicBtn.innerText = '🔇 Music Off';
                isMusicPlaying = false;
                localStorage.setItem('musicPlaying', 'false');
            } else {
                bgVideo.muted = false;
                bgVideo.volume = 0.2;
                musicBtn.innerText = '🎵 Music On';
                isMusicPlaying = true;
                localStorage.setItem('musicPlaying', 'true');
                if (bgVideo.paused) {
                    bgVideo.play().catch(e => console.log('Play error:', e));
                }
            }
        });

        // ================================================================
        // 5. SYNC MUSIC STATE WITH OTHER PAGES (image, video, tatti)
        // ================================================================
        // When coming back from other pages, check localStorage
        document.addEventListener('visibilitychange', () => {
            if (!document.hidden) {
                const savedState = localStorage.getItem('musicPlaying');
                if (savedState === 'true' && !isMusicPlaying) {
                    // Music should be playing but isn't
                    bgVideo.muted = false;
                    bgVideo.volume = 0.2;
                    musicBtn.innerText = '🎵 Music On';
                    isMusicPlaying = true;
                    bgVideo.play().catch(e => console.log('Play error:', e));
                } else if (savedState === 'false' && isMusicPlaying) {
                    bgVideo.muted = true;
                    musicBtn.innerText = '🔇 Music Off';
                    isMusicPlaying = false;
                }
            }
        });

        console.log('🎂 2025 page loaded – responsive video fixed!');
    </script>
</body>
</html>